{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/demo/backend/WeatherApiService.Api/WeatherApiService.Api.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Start Weather API",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "demo/backend/WeatherApiService.Api/WeatherApiService.Api.csproj"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Start Weather Frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/demo/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Weather Full Stack",
      "dependsOn": [
        "Start Weather API",
        "Start Weather Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
